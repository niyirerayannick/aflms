## ─── AFLMS / ATMS ─── Environment Variables ───────────────────────
## Copy this file to .env and fill in real values.
## For Coolify: paste these into the Environment Variables section.

# ── Django Core ──────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=aflms.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Coolify auto-injects this when you link a PostgreSQL service.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://aflms:aflms@db:5432/aflms
DATABASE_SSL_REQUIRE=False

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Email ─────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@aflms.local

# ── Site ──────────────────────────────────────────────────────────
SITE_ID=1
TAILWIND_APP_NAME=theme

# ── Cloudinary (optional) ────────────────────────────────────────
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Sentry (optional) ────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=False

# ── Security (production) ────────────────────────────────────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Twilio WhatsApp Integration ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_STATUS_CALLBACK_URL=https://yourdomain.com/api/whatsapp/status/

# ── Superuser (auto-created on first deploy) ─────────────────────
DJANGO_SUPERUSER_EMAIL=admin@aflms.local
DJANGO_SUPERUSER_PASSWORD=change-me